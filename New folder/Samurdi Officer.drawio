        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart LR\n    classDef usecase fill:#1a1a1a,stroke:#ffffff,stroke-width:2px,color:#ffffff,rx:50,ry:50;\n    classDef actor fill:transparent,stroke:none,color:#ffffff;\n\n    Actor((👤&lt;br&gt;Samurdhi Officer)):::actor\n\n    UC_Login([Login to the system]):::usecase\n    UC_Dash([View Dashboard]):::usecase\n    \n    %% New Tasks for Deviceless Applicants\n    UC_CreateAcc([Create Applicant Account]):::usecase\n    UC_SubmitApp([Submit Application for Applicant]):::usecase\n    \n    %% Existing Tasks\n    UC_View([View Applications]):::usecase\n    UC_Visit([Conduct Home Visit]):::usecase\n    UC_Approve([Approve &amp; Forward to GN]):::usecase\n\n    Actor --- UC_Login\n    \n    UC_Dash -. \&quot;«ext»\&quot; .-&gt; UC_Login\n    UC_CreateAcc -. \&quot;«ext»\&quot; .-&gt; UC_Login\n    UC_SubmitApp -. \&quot;«ext»\&quot; .-&gt; UC_Login\n    UC_View -. \&quot;«ext»\&quot; .-&gt; UC_Login\n    UC_Visit -. \&quot;«ext»\&quot; .-&gt; UC_Login\n    UC_Approve -. \&quot;«ext»\&quot; .-&gt; UC_Login\n    \n    %% Flow 1: Helping deviceless applicants\n    UC_CreateAcc -. \&quot;«Inc»\&quot; .-&gt; UC_SubmitApp\n    \n    %% Flow 2: Approving applications\n    UC_View -. \&quot;«Inc»\&quot; .-&gt; UC_Visit\n    UC_Visit -. \&quot;«Inc»\&quot; .-&gt; UC_Approve&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="IOa4-MWvAUdTQVhdvQfZ-474">
